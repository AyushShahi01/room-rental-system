# ─── Django ──────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=project.settings
DEBUG=True

# ─── Database (PostgreSQL — used in prod, optional in dev) ──────────────────
DB_NAME=project_db
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432

# ─── Allowed Hosts (comma-separated for prod) ──────────────────────────────
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── CORS Allowed Origins (comma-separated for prod) ───────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Email (SMTP — used in prod) ───────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@example.com

# ─── OTP ───────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10

# Payment Gateways
KHALTI_SECRET_KEY=your-khalti-secret-key
KHALTI_API_BASE_URL=https://dev.khalti.com/api/v2
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_API_BASE_URL=https://rc.esewa.com.np

# Firebase Cloud Messaging
FIREBASE_CREDENTIALS_PATH=/absolute/path/to/firebase-service-account.json
